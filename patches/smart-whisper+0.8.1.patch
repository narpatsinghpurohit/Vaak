+  // node-gyp configure time (libraries getter) on a machine with the Xcode toolchain.
+  function embed_metal_library() {
+    const fs = require("fs");
+    const cp = require("child_process");
+    const path = require("path");
+    const root = path.join(__dirname, "..");
+    const metal = path.join(root, "whisper.cpp/ggml/src/ggml-metal.metal");
+    const asm = path.join(root, "whisper.cpp/ggml/src/ggml-metal-embed.s");
+    const obj = path.join(root, "whisper.cpp/ggml/src/ggml-metal-embed.o");
+    const asm_src =
+      ".section __DATA,__ggml_metallib\n" +
+      ".globl _ggml_metallib_start\n" +
+      "_ggml_metallib_start:\n" +
+      '.incbin "' + metal + '"\n' +
+      ".globl _ggml_metallib_end\n" +
+      "_ggml_metallib_end:\n";
+    fs.writeFileSync(asm, asm_src);
+    cp.execSync("cc -c " + JSON.stringify(asm) + " -o " + JSON.stringify(obj));
